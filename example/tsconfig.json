{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ES2024", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2024",
    "types": ["@cloudflare/workers-types", "node"]
  },
  "include": ["*.ts", "src/**/*.ts", "scripts/**/*.ts", "app/src/**/*.ts"]
}
