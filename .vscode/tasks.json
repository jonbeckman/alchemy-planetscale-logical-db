{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "term (workspace 1)",
      "type": "process",
      "command": "${env:SHELL}",
      "args": ["-l"],
      "options": {
        "cwd": "${workspaceFolder}/"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": false,
        "focus": true,
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 10
      }
    }
  ]
}
